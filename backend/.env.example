# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://<your-project-id>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-publishable-key>
SUPABASE_BUCKET=semantica-uploads

# ── NVIDIA NIM ────────────────────────────────────────────────────────────────
# Get your API key at: https://build.nvidia.com
NVIDIA_API_KEY=nvapi-<your-nvidia-api-key>

# ── Model selection ───────────────────────────────────────────────────────────
NIM_MODEL_DEFAULT=meta/llama-3.1-70b-instruct
NIM_MODEL_CODER=meta/llama-3.1-70b-instruct
# Optional: override Pro/Flash routing models
# NIM_MODEL_PRO=meta/llama-3.1-70b-instruct
# NIM_MODEL_FLASH=meta/llama-3.1-70b-instruct

# ── DS-STAR Agent tuning ──────────────────────────────────────────────────────
MAX_AGENT_ROUNDS=10
EXECUTION_TIMEOUT_SECONDS=30
MAX_TOKENS_PER_RUN=50000
MAX_DEBUGGER_RETRIES=3

# ── DS-STAR+ deep research ────────────────────────────────────────────────────
DS_STAR_PLUS_MAX_WORKERS=3

# ── Session management ────────────────────────────────────────────────────────
# Seconds before an idle session context is evicted from memory
SESSION_TTL_SECONDS=3600
# Maximum concurrent session contexts held in memory
MAX_SESSIONS=500

# ── Docker sandbox (optional) ─────────────────────────────────────────────────
# Set to true in production to run generated code inside a Docker container
DOCKER_SANDBOX_ENABLED=false
DOCKER_SANDBOX_IMAGE=python:3.11-slim
DOCKER_MEMORY_LIMIT=512m
DOCKER_CPU_QUOTA=0.5

# ── Redis / Celery (deferred — requires Redis) ────────────────────────────────
# REDIS_URL=redis://localhost:6379
